{
  "name": "gestop",
  "version": "1.0.0",
  "description": "Backend NestJS da plataforma GestOP",
  "main": "dist/src/main.js",
  "scripts": {
    "build": "prisma generate && tsc -p tsconfig.build.json",
    "dev": "tsx watch src/main.ts",
    "start": "node dist/prisma/startup.js && node dist/src/main.js",
    "test": "prisma generate && vitest run",
    "test:watch": "vitest",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:seed": "tsx prisma/seed.ts",
    "admin:reset-password": "tsx prisma/reset-admin-password.ts",
    "import:unidades": "tsx prisma/import-unidades.ts",
    "import:unidades:dry-run": "tsx prisma/import-unidades.ts --dry-run",
    "import:secretarias": "tsx prisma/import-secretarias.ts",
    "import:secretarias:dry-run": "tsx prisma/import-secretarias.ts --dry-run",
    "go-live:check": "tsx scripts/go-live-check.ts",
    "vapid:generate": "tsx scripts/generate-vapid-keys.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1057.0",
    "@emnapi/core": "^1.10.0",
    "@emnapi/runtime": "^1.10.0",
    "@nestjs/common": "^11.1.21",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.21",
    "@nestjs/platform-express": "^11.1.21",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@sentry/node": "^10.55.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "pdfkit": "^0.18.0",
    "pg": "^8.21.0",
    "prisma": "^7.8.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "typescript": "^6.0.3",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/node": "^25.9.0",
    "@types/pdfkit": "^0.17.6",
    "@types/pg": "^8.20.0",
    "@types/web-push": "^3.6.4",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.2",
    "vitest": "^4.1.6"
  }
}
