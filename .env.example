# Backend (NestJS + Prisma)
DATABASE_URL="postgresql://gestop:gestop@localhost:5432/gestop?schema=public"
PORT=3001
NODE_ENV=development
JWT_SECRET="troque-este-segredo-em-producao-com-pelo-menos-32-caracteres"
# CORS_ORIGINS=https://seu-frontend.up.railway.app

# Primeiro deploy em producao (seed inicial)
INITIAL_ADMIN_PASSWORD="DefinaUmaSenhaForteCom12+Chars"

# Armazenamento de evidencias (fotos do mobile)
# Railway: use STORAGE_DRIVER=local + Volume persistente (ver docs/fase-1-go-live.md)
STORAGE_DRIVER=local
STORAGE_LOCAL_DIR=./storage
STORAGE_PUBLIC_URL_BASE=http://localhost:3001
STORAGE_MAX_FILE_BYTES=26214400

# --- Railway (producao) — exemplo ---
# STORAGE_DRIVER=local
# STORAGE_LOCAL_DIR=/data/gestop-evidencias
# STORAGE_PUBLIC_URL_BASE=https://SEU-FRONTEND.up.railway.app/api-sigma

# --- Opcional: storage externo S3-compatible (NAO e AWS obrigatorio) ---
# STORAGE_DRIVER=s3
# S3_BUCKET=gestop-evidencias
# S3_REGION=auto
# S3_ENDPOINT=https://...
# S3_ACCESS_KEY_ID=...
# S3_SECRET_ACCESS_KEY=...
# S3_PUBLIC_URL_BASE=https://...

# INTEGRACOES_WEBHOOK_URL=https://sistema-municipal.exemplo/webhook/gestop
# INTEGRACOES_WEBHOOK_SECRET=segredo-compartilhado
# FRONTEND_PUBLIC_URL=https://SEU-FRONTEND.up.railway.app
# LGPD_AUDIT_RETENTION_DAYS=365
# SENTRY_DSN=https://...@sentry.io/...   # opcional — monitoramento de erros
# SENTRY_TRACES_SAMPLE_RATE=0.1
# WEB_PUSH_VAPID_PUBLIC_KEY=...
# WEB_PUSH_VAPID_PRIVATE_KEY=...
# WEB_PUSH_VAPID_SUBJECT=mailto:gestop@franca.sp.gov.br
# ALERTAS_INTERVAL_MS=21600000   # 6h — disparo automatico de alertas (0 desliga)
# SYNC_REPLAY_INTERVAL_MS=1800000  # 30min — replay automatico de sync offline pendente (0 desliga)
# FORCE_DB_RESET=false
# FORCE_SEED_ON_START=false
