# Backend (NestJS + Prisma)
DATABASE_URL="postgresql://gestop:gestop@localhost:5432/gestop?schema=public"
PORT=3001
NODE_ENV=development
JWT_SECRET="troque-este-segredo-em-producao-com-pelo-menos-32-caracteres"
# CORS_ORIGINS=https://seu-frontend.up.railway.app

# Primeiro deploy em producao (seed inicial)
INITIAL_ADMIN_PASSWORD="DefinaUmaSenhaForteCom12+Chars"

# Armazenamento de evidencias (fotos do mobile)
# Railway: use STORAGE_DRIVER=local + Volume persistente (ver docs/fase-1-go-live.md)
STORAGE_DRIVER=local
STORAGE_LOCAL_DIR=./storage
STORAGE_PUBLIC_URL_BASE=http://localhost:3001
STORAGE_MAX_FILE_BYTES=10485760

# --- Railway (producao) — exemplo ---
# STORAGE_DRIVER=local
# STORAGE_LOCAL_DIR=/data/gestop-evidencias
# STORAGE_PUBLIC_URL_BASE=https://SEU-FRONTEND.up.railway.app/api-gestop

# --- Opcional: storage externo S3-compatible (NAO e AWS obrigatorio) ---
# STORAGE_DRIVER=s3
# S3_BUCKET=gestop-evidencias
# S3_REGION=auto
# S3_ENDPOINT=https://...
# S3_ACCESS_KEY_ID=...
# S3_SECRET_ACCESS_KEY=...
# S3_PUBLIC_URL_BASE=https://...

# Bootstrap do banco (usar com cuidado em producao)
# FORCE_DB_RESET=false
# FORCE_SEED_ON_START=false
